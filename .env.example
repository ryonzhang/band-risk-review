# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- MongoDB Atlas (DataAgent source via the MongoDB MCP server) ---
# Free-tier (M0) connection string. Run `python seed_atlas.py` to load the data.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB=band_risk_review

# --- Band platform (fill in at the June 12 kickoff) ---
THENVOI_REST_URL=https://app.band.ai/
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# The shared room the four agents collaborate in (created at app.band.ai).
BAND_ROOM_ID=

# --- LLM narration layer (parse question + narrate decision ONLY) ---
# Prefer the AI/ML API unified endpoint (partner prize); fall back to Anthropic.
# The LLM must NEVER compute a risk number — those come only from risk_core.py.
AIML_API_KEY=
AIML_API_BASE=https://api.aimlapi.com/v1
ANTHROPIC_API_KEY=
