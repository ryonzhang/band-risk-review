# ---- Band platform ----
THENVOI_REST_URL=https://app.band.ai
THENVOI_WS_URL=wss://app.band.ai/api/v1/socket/websocket
# Your Band username (the part before the / in your agent handles).
BAND_OWNER_HANDLE=your-username
# The chat room the four agents collaborate in (used by post_question.py /
# read_transcript.py). Copy the uuid from the room URL: app.band.ai/chat/<uuid>.
BAND_ROOM_ID=

# ---- LLM provider that powers the agents' reasoning ----
# band_agents.py uses Gemini (no first-class Band Gemini adapter, so it calls the
# Gemini API directly for narration/intent and risk_tools for every number).
GEMINI_API_KEY=your-gemini-key-here
GOOGLE_API_KEY=your-gemini-key-here
CALIBRATED_COPILOT_MODEL=gemini-3.1-pro-preview-customtools
# Or point at AI/ML API / Anthropic if you swap the provider in _gemini().
ANTHROPIC_API_KEY=
